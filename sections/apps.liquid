{%- if section.settings.section_reviews -%}
{{ 'section-reviews.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- liquid
  assign show_apps_section = true

  if page.handle == 'swatches'
    assign show_apps_section = false

    if customer and customer.b2b?
      assign show_apps_section = true
    endif
  endif
-%}

{% if show_apps_section %}
{%- if section.settings.section_reviews -%}
  <div class="rave-reviews">
  <div class="rave-reviews-main" id="rave-reviews-main">
{%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading | default: 'Rave Reviews' }}</h2>
  {%- endif -%}
  
  <div class="{% if section.settings.include_margins %}page-width{% endif %}">
    {% for block in section.blocks %}
      {% render block %}
    {% endfor %}
  </div>
    
{%- if section.settings.section_reviews -%}
  </div>
  </div>
{%- endif -%}
{% endif %}

{% schema %}
{
  "name": "t:sections.apps.name",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "include_margins",
      "default": true,
      "label": "t:sections.apps.settings.include_margins.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "section_reviews",
      "default": true,
      "label": "Check this if the section is reviews section"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.apps.presets.name"
    }
  ]
}
{% endschema %}
