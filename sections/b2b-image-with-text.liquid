{{ 'b2b-image-with-text.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign show_section = true
  if section.settings.b2b_only
    assign show_section = false
    if customer and customer.b2b?
      assign show_section = true
    endif
  endif
-%}

{%- if show_section -%}

{%- style -%}
  #fifty-fifty-{{ section.id }} {
    --fifty-fifty-bg-color: {{ section.settings.bg_color }};
    --fifty-fifty-padding-top: {{ section.settings.padding_top }}px;
    --fifty-fifty-padding-bottom: {{ section.settings.padding_bottom }}px;
    --fifty-fifty-container-width: {{ section.settings.container_width }}px;
    --fifty-fifty-column-gap: {{ section.settings.column_gap }}px;
    --fifty-fifty-image-height: {{ section.settings.image_height }}px;
    --fifty-fifty-image-radius: {{ section.settings.image_radius }}px;
    --fifty-fifty-sub-text-color: {{ section.settings.sub_text_color }};
    --fifty-fifty-heading-color: {{ section.settings.heading_color }};
    --fifty-fifty-heading-size: {{ section.settings.heading_size }}px;
    --fifty-fifty-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --fifty-fifty-body-color: {{ section.settings.body_color }};
    --fifty-fifty-body-size: {{ section.settings.body_size }}px;
    --fifty-fifty-button-bg-color: {{ section.settings.button_bg_color }};
    --fifty-fifty-button-text-color: {{ section.settings.button_text_color }};
    --fifty-fifty-button-radius: {{ section.settings.button_radius }}px;
    --fifty-fifty-footnote-color: {{ section.settings.footnote_color }};
    --fifty-fifty-link-color: {{ section.settings.link_color }};
  }
{%- endstyle -%}

<div class="fifty-fifty" id="fifty-fifty-{{ section.id }}">
  <div class="fifty-fifty__inner{% if section.settings.image_position == 'right' %} fifty-fifty__inner--image-right{% endif %}">

    <div class="fifty-fifty__image{% if section.settings.image == blank %} fifty-fifty__image--placeholder{% endif %}">
      {%- if section.settings.image != blank -%}
        <img
          class="fifty-fifty__image-media"
          src="{{ section.settings.image | image_url: width: 1600 }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      {%- endif -%}
    </div>

    <div class="fifty-fifty__content">
      {%- if section.settings.eyebrow != blank -%}
        <div class="fifty-fifty__sub-text">{{ section.settings.eyebrow }}</div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="fifty-fifty__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body_text != blank -%}
        <div class="fifty-fifty__body">{{ section.settings.body_text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="fifty-fifty__button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.footnote_text != blank -%}
        <div class="fifty-fifty__footnote">
          {{ section.settings.footnote_text }}
          {%- if section.settings.footnote_link_text != blank -%}
            <a href="{{ section.settings.footnote_link | default: '#' }}" class="fifty-fifty__footnote-link">{{ section.settings.footnote_link_text }}</a>
          {%- endif -%}
          {%- if section.settings.footnote_text_after != blank -%}
            {{ section.settings.footnote_text_after }}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "50/50 Image With Text",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "b2b_only",
      "label": "Only show this section to B2B customers",
      "default": false,
      "info": "Uses {% raw %}{% if customer and customer.b2b? %}{% endraw %} to check for a logged-in B2B company customer."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "info": "On mobile, the image always stacks above the text."
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Max content width",
      "min": 1000,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Gap between columns",
      "min": 20,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image min height",
      "min": 300,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 560
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "TRADE PERK"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See It. Feel It. Make the Call."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (desktop)",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Trade members receive five complimentary swatches of their choice—so you can see the color, feel the texture, and move forward with confidence.</p>"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Select Your 5 Swatches"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 2
    },
    {
      "type": "header",
      "content": "Footnote / secondary link"
    },
    {
      "type": "text",
      "id": "footnote_text",
      "label": "Footnote text (before link)",
      "default": "Not a trade member yet?"
    },
    {
      "type": "text",
      "id": "footnote_link_text",
      "label": "Footnote link text",
      "default": "Join below ↓"
    },
    {
      "type": "url",
      "id": "footnote_link",
      "label": "Footnote link URL"
    },
    {
      "type": "text",
      "id": "footnote_text_after",
      "label": "Footnote text (after link)",
      "default": "— applications are reviewed within 24 hours."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#F2EEE6"
    },
    {
      "type": "color",
      "id": "sub_text_color",
      "label": "Sub text color",
      "default": "#B08D4F"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#5A6B82"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#2B2B2B"
    },
    {
      "type": "color",
      "id": "footnote_color",
      "label": "Footnote text color",
      "default": "#8A8579"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Footnote link color",
      "default": "#5A6B82"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#C6A15B"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#1A1A1A"
    }
  ],
  "presets": [
    {
      "name": "50/50 Image With Text"
    }
  ]
}
{% endschema %}
