{{ 'section-shop-by-category.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section__shop--by-category section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }}">
    <div class="page-width">
        <div class="header__shop--by-category">
            {% if section.settings.sub_heading != blank %}
                <div class="header__sub--heading">{{ section.settings.sub_heading }}</div>
            {% endif %}
            {% if section.settings.heading != blank %}
                <h2 class="blue header__heading">{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.text != blank %}
                <p class="header__text">{{ section.settings.text }}</p>
            {% endif %}
            {% if section.settings.btn_label != blank and section.settings.btn_link != blank %}
                <a class="shop-all-btn" href="{{ section.settings.btn_link }}">{{ section.settings.btn_label }}</a>
            {% endif %}
        </div>
        <div class="category__carousel--container">
            <div class="category__carousel--wrapper category__carousel--{{ section.id }} swiper">
                <div class="swiper-wrapper">
                    {% for block in section.blocks %}
                        <div class="category__carousel--item swiper-slide">
                            <a href="{{ block.settings.url }}">
                                <div class="image__block">
                                    {{
                                    block.settings.image
                                    | image_url: width: 1000
                                    | image_tag:
                                        loading: 'lazy',
                                        widths: '320, 480, 640, 800, 1000',
                                        sizes: '(max-width: 768px) 50vw, 20vw',
                                        class: 'testimonials-slider__gallery-image',
                                        alt: block.settings.image.alt | default: block.settings.author_name
                                    }}
                                </div>
                                <div class="categories__item--text">
                                    {{ block.settings.text }}
                                </div>
                            </a>
                        </div>
                    {% endfor %}
                </div>
                <div class="category-swiper-pagination"></div>
            </div>
            <div class="category-swiper-button-next category-swiper-button">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <div class="category-swiper-button-prev category-swiper-button">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M15 6L9 12L15 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </div>
        {% if section.settings.btn_label != blank and section.settings.btn_link != blank %}
            <a class="shop-all-btn" href="{{ section.settings.btn_link }}">{{ section.settings.btn_label }}</a>
        {% endif %}
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", (event) => {
        var swiper = new Swiper(".category__carousel--{{ section.id }}", {
            slidesPerView: 3.1,
            spaceBetween: 8,
            navigation: {
                nextEl: ".category-swiper-button-next",
                prevEl: ".category-swiper-button-prev",
            },
            pagination: {
                el: ".category-swiper-pagination",
            },
            breakpoints: {
                768: {
                    slidesPerView: 3,
                    spaceBetween: 12,
                },
                1200: {
                    slidesPerView: 4,
                    spaceBetween: 12,
                },
            },
        });
    });
</script>

{% schema %}
{
  "name": "Categories Grid",
  "settings": [
    {
        "type": "color",
        "id": "bg_color",
        "label": "Background"
    },
    {
        "type": "text",
        "id": "sub_heading",
        "label": "Sub heading"
    },
    {
        "type": "text",
        "id": "heading",
        "label": "Heading"
    },
    {
        "type": "text",
        "id": "text",
        "label": "Text"
    },
    {
        "type": "text",
        "id": "btn_label",
        "label": "Button label"
    },
    {
        "type": "url",
        "id": "btn_link",
        "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
     "type": "block",
     "name": "block",
     "settings": [ 
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop By Category",
      "settings": {}
    }
  ]
}
{% endschema %}